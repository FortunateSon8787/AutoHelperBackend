{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=autohelper;Username=autohelper;Password=autohelper"
  },
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "ValidAudiences": [ "autohelper-api" ],
        "ValidIssuers": [ "autohelper-api" ]
      }
    }
  },
  "Jwt": {
    "Secret": "CHANGE_ME_IN_PRODUCTION_USE_USER_SECRETS",
    "Issuer": "autohelper-api",
    "Audience": "autohelper-api",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Storage": {
    "ServiceUrl": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "autohelper"
  },
  "Stripe": {
    "SecretKey": "CHANGE_ME",
    "WebhookSecret": "CHANGE_ME"
  },
  "OpenAI": {
    "ApiKey": "CHANGE_ME",
    "Model": "gpt-4o"
  },
  "AllowedHosts": "*"
}
