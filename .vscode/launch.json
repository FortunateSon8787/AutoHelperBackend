{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AutoHelper.Api — Debug",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/AutoHelper.Api/bin/Debug/net10.0/AutoHelper.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/AutoHelper.Api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7001;http://localhost:5001"
      },
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "AutoHelper.Api — Attach",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
